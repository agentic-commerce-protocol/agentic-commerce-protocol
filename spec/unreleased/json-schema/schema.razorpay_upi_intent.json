{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://razorpay.com/acp/upi_intent/2026-04-07/schema.json",
  "title": "Razorpay UPI Intent Handler - Schema Bundle",
  "description": "JSON Schema definitions for the Razorpay UPI Intent payment handler for ACP (Agentic Commerce Protocol). Enables UPI payments via deep links on mobile and QR codes on desktop.",
  "$defs": {
    "HandlerConfig": {
      "description": "Configuration for the Razorpay UPI Intent handler",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "merchant_id": {
          "type": "string",
          "pattern": "^rzp_(test_|live_)?[a-zA-Z0-9]+$",
          "description": "Razorpay account identifier (MID / key_id)"
        },
        "merchant_vpa": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z0-9]+$",
          "description": "Merchant VPA (unique-name@bank-handle or mobile-number@bank-handle)"
        },
        "environment": {
          "type": "string",
          "enum": ["test", "production"],
          "description": "Razorpay API environment"
        }
      },
      "required": ["merchant_id", "merchant_vpa", "environment"],
      "example": {
        "merchant_id": "acc_KN2V9oR1g9n0qH",
        "merchant_vpa": "storename@icici",
        "environment": "production"
      }
    },
    "UPIPaymentProvider": {
      "description": "Payment provider configuration for UPI Intent in requestCheckout",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "const": "razorpay",
          "description": "Payment provider name - must be 'razorpay'"
        },
        "merchant_id": {
          "type": "string",
          "pattern": "^rzp_(test_|live_)?[a-zA-Z0-9]+$",
          "description": "Razorpay merchant identifier"
        },
        "payment_type": {
          "type": "string",
          "const": "upi_intent",
          "description": "Must be 'upi_intent' for this handler"
        },
        "handler_id": {
          "type": "string",
          "description": "Reference to handler configuration ID"
        }
      },
      "required": ["name", "merchant_id", "payment_type", "handler_id"]
    },
    "Credential": {
      "description": "UPI Intent credential for credential-on-escalation flow",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "upi_intent",
          "description": "Always 'upi_intent'"
        },
        "intent_uri": {
          "type": "string",
          "format": "uri",
          "description": "NPCI-compliant UPI intent URI (upi:// scheme) for mobile execution"
        },
        "transaction_reference": {
          "type": "string",
          "maxLength": 35,
          "description": "Transaction reference ID (max 35 alphanumeric chars per NPCI spec)"
        },
        "qr_code_data": {
          "type": "string",
          "description": "Base64-encoded PNG QR code image for desktop rendering"
        },
        "qr_code_string": {
          "type": "string",
          "description": "UPI intent URI string for QR code generation on desktop"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "Credential expiry timestamp (NPCI best practice: 15 minutes)"
        }
      },
      "required": ["type", "intent_uri", "transaction_reference", "expires_at"],
      "example": {
        "type": "upi_intent",
        "intent_uri": "upi://pay?pa=storename@icici&pn=MyStore&tr=ORD123456&am=500.00&cu=INR&tn=Order%20123456&mc=5411&mode=04",
        "transaction_reference": "ORD123456",
        "qr_code_data": "data:image/png;base64,iVBORw0KGgo...",
        "qr_code_string": "upi://pay?pa=storename@icici&pn=MyStore&tr=ORD123456&am=500.00&cu=INR",
        "expires_at": "2026-04-07T12:15:00Z"
      }
    },
    "Instrument": {
      "description": "Instrument for UPI Intent payment type",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Instrument identifier"
        },
        "handler_id": {
          "type": "string",
          "description": "Reference to the handler configuration ID"
        },
        "type": {
          "type": "string",
          "const": "upi_intent",
          "description": "Always 'upi_intent'"
        },
        "selected": {
          "type": "boolean",
          "description": "Whether this instrument is selected"
        },
        "display": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "description": "Display name"
            },
            "logo": {
              "type": "string",
              "format": "uri",
              "description": "Logo URL"
            }
          }
        },
        "credential": {
          "$ref": "#/$defs/Credential"
        }
      },
      "required": ["id", "handler_id", "type"]
    },
    "RazorpayOrderRequest": {
      "description": "Request to create Razorpay order for UPI Intent",
      "type": "object",
      "properties": {
        "amount": {
          "type": "integer",
          "minimum": 100,
          "description": "Amount in paise"
        },
        "currency": {
          "type": "string",
          "const": "INR"
        },
        "receipt": {
          "type": "string",
          "maxLength": 40,
          "description": "Internal reference"
        },
        "notes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "acp_checkout_id": {
              "type": "string",
              "description": "ACP checkout session ID"
            }
          }
        }
      },
      "required": ["amount", "currency"]
    },
    "RazorpayOrderResponse": {
      "description": "Response from Razorpay Orders API",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^order_[a-zA-Z0-9]+$"
        },
        "entity": {
          "type": "string",
          "const": "order"
        },
        "amount": {
          "type": "integer"
        },
        "amount_paid": {
          "type": "integer"
        },
        "amount_due": {
          "type": "integer"
        },
        "currency": {
          "type": "string",
          "const": "INR"
        },
        "receipt": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["created", "attempted", "paid"]
        },
        "attempts": {
          "type": "integer"
        },
        "notes": {
          "type": "object"
        },
        "created_at": {
          "type": "integer",
          "description": "Unix timestamp"
        }
      }
    },
    "UPIIntentParameters": {
      "description": "NPCI UPI Linking Specification parameters",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pa": {
          "type": "string",
          "description": "Payee VPA (mandatory)"
        },
        "pn": {
          "type": "string",
          "description": "Payee display name (mandatory)"
        },
        "am": {
          "type": "string",
          "description": "Amount in decimal (e.g., 500.00) - conditional"
        },
        "cu": {
          "type": "string",
          "const": "INR",
          "description": "Currency code - must be INR"
        },
        "tr": {
          "type": "string",
          "maxLength": 35,
          "description": "Transaction reference (max 35 alphanumeric chars) - conditional for merchant payments"
        },
        "tn": {
          "type": "string",
          "maxLength": 50,
          "description": "Transaction note (max 50 chars) - optional"
        },
        "mc": {
          "type": "string",
          "pattern": "^[0-9]{4}$",
          "description": "4-digit Merchant Category Code (MCC) - optional"
        },
        "mode": {
          "type": "string",
          "enum": ["04", "05"],
          "description": "04 = Intent, 05 = Merchant QR - optional"
        }
      },
      "required": ["pa", "pn"]
    },
    "CompleteCheckoutPaymentData": {
      "description": "Payment data for complete_checkout MCP tool with UPI Intent",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "upi_intent"
        },
        "provider": {
          "type": "string",
          "const": "razorpay"
        },
        "payment_id": {
          "type": "string",
          "pattern": "^pay_[a-zA-Z0-9]+$",
          "description": "Razorpay payment ID"
        },
        "order_id": {
          "type": "string",
          "pattern": "^order_[a-zA-Z0-9]+$",
          "description": "Razorpay order ID"
        },
        "transaction_reference": {
          "type": "string",
          "maxLength": 35,
          "description": "Transaction reference used in intent URI"
        },
        "upi_txn_id": {
          "type": "string",
          "description": "NPCI UPI transaction ID"
        },
        "status": {
          "type": "string",
          "enum": ["captured", "failed", "pending"]
        },
        "signature": {
          "type": "string",
          "description": "Razorpay HMAC-SHA256 signature for verification"
        },
        "amount": {
          "type": "integer",
          "minimum": 100
        },
        "currency": {
          "type": "string",
          "const": "INR"
        },
        "method": {
          "type": "string",
          "const": "upi"
        },
        "vpa": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z0-9]+$",
          "description": "User's UPI VPA used for payment"
        }
      },
      "required": ["type", "provider", "payment_id", "order_id", "transaction_reference", "upi_txn_id", "status", "signature", "amount", "currency"]
    },
    "WebhookPaymentAuthorized": {
      "description": "Razorpay webhook event for successful UPI payment",
      "type": "object",
      "properties": {
        "event": {
          "type": "string",
          "const": "payment.authorized"
        },
        "payload": {
          "type": "object",
          "properties": {
            "payment": {
              "type": "object",
              "properties": {
                "entity": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "order_id": { "type": "string" },
                    "status": { "type": "string" },
                    "amount": { "type": "integer" },
                    "currency": { "type": "string", "const": "INR" },
                    "method": { "type": "string", "const": "upi" },
                    "vpa": { "type": "string" },
                    "upi_transaction_id": { "type": "string" },
                    "notes": {
                      "type": "object",
                      "properties": {
                        "acp_checkout_id": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "WebhookPaymentFailed": {
      "description": "Razorpay webhook event for failed UPI payment",
      "type": "object",
      "properties": {
        "event": {
          "type": "string",
          "const": "payment.failed"
        },
        "payload": {
          "type": "object",
          "properties": {
            "payment": {
              "type": "object",
              "properties": {
                "entity": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "order_id": { "type": "string" },
                    "status": { "type": "string", "const": "failed" },
                    "error_code": { "type": "string" },
                    "error_description": { "type": "string" },
                    "notes": {
                      "type": "object",
                      "properties": {
                        "acp_checkout_id": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "ErrorPaymentDeclined": {
      "description": "User declined or UPI app declined payment",
      "type": "object",
      "properties": {
        "code": { "type": "string", "const": "payment_declined" },
        "severity": { "type": "string", "const": "recoverable" },
        "message": { "type": "string", "const": "Payment was declined by the UPI app. Please retry or choose a different payment method." },
        "npci_code": { "type": "string", "description": "NPCI response code (e.g., ZM, Z9, U28)" }
      }
    },
    "ErrorInsufficientFunds": {
      "description": "Insufficient funds in UPI account",
      "type": "object",
      "properties": {
        "code": { "type": "string", "const": "insufficient_funds" },
        "severity": { "type": "string", "const": "recoverable" },
        "message": { "type": "string", "const": "Insufficient funds. Please add funds to your UPI account and retry." },
        "npci_code": { "type": "string", "const": "Z9" }
      }
    },
    "ErrorVPAInvalid": {
      "description": "Merchant VPA misconfigured",
      "type": "object",
      "properties": {
        "code": { "type": "string", "const": "merchant_configuration_error" },
        "severity": { "type": "string", "const": "recoverable" },
        "message": { "type": "string", "const": "Merchant UPI configuration error. Please contact merchant support." },
        "npci_code": { "type": "string", "const": "U28" }
      }
    },
    "ErrorTimeout": {
      "description": "Buyer didn't complete payment in time",
      "type": "object",
      "properties": {
        "code": { "type": "string", "const": "payment_timeout" },
        "severity": { "type": "string", "const": "recoverable" },
        "message": { "type": "string", "const": "Payment time expired. Please retry with a new QR code or intent link." }
      }
    },
    "ErrorNetworkUnavailable": {
      "description": "NPCI network unavailable",
      "type": "object",
      "properties": {
        "code": { "type": "string", "const": "network_error" },
        "severity": { "type": "string", "const": "recoverable" },
        "message": { "type": "string", "const": "UPI network temporarily unavailable. Please retry in a few minutes." },
        "npci_code": { "type": "string", "const": "BT" }
      }
    }
  }
}
