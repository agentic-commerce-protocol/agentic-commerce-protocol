{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/s2s-cards/bundle.schema.json",
  "title": "S2S Cards Handler \u2014 Schema Bundle",
  "description": "JSON Schema definitions for the Server-to-Server (S2S) card payment handler for ACP. Enables native in-chat tokenized card payments with 3DS support and Card-on-File Tokenization (CoFT) compliance.",
  "$defs": {
    "BusinessConfig": {
      "description": "Configuration for the S2S Cards handler provided by the business. Declared in the business's ACP handler configuration.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "type": "string",
          "description": "PSP API key identifier for this business account"
        },
        "environment": {
          "type": "string",
          "enum": ["sandbox", "production"],
          "description": "PSP API environment. Use 'sandbox' for test mode, 'production' for live mode."
        },
        "supported_networks": {
          "type": "array",
          "description": "Card networks accepted by this handler",
          "items": {
            "type": "string",
            "enum": ["visa", "mastercard", "rupay", "amex"]
          },
          "default": ["visa", "mastercard", "rupay", "amex"]
        },
        "supported_types": {
          "type": "array",
          "description": "Card funding types accepted by this handler",
          "items": {
            "type": "string",
            "enum": ["credit", "debit"]
          },
          "default": ["credit", "debit"]
        },
        "emi_enabled": {
          "type": "boolean",
          "description": "Whether to offer EMI plans on eligible cards",
          "default": false
        },
        "save_cards": {
          "type": "boolean",
          "description": "Whether to offer save-card option via PSP tokenization",
          "default": true
        }
      },
      "required": ["key_id", "environment"],
      "example": {
        "key_id": "psp_live_abc123xyz",
        "environment": "production",
        "supported_networks": ["visa", "mastercard", "rupay", "amex"],
        "supported_types": ["credit", "debit"],
        "emi_enabled": true,
        "save_cards": true
      }
    },
    "PlatformConfig": {
      "description": "Platform-level configuration for the S2S Cards handler. Declared in the platform's ACP handler configuration.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["sandbox", "production"],
          "description": "PSP API environment. Must match the business config environment."
        }
      },
      "example": {
        "environment": "production"
      }
    },
    "PaymentMethodS2SCard": {
      "description": "Tokenized card payment method for S2S card payments. Raw PANs are never transmitted; all card data is represented via a PSP-issued token.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "s2s_card",
          "description": "Payment method type, always 's2s_card'"
        },
        "token_id": {
          "type": "string",
          "description": "PSP token ID representing the tokenized card (never a raw PAN)"
        },
        "card_network": {
          "type": "string",
          "enum": ["Visa", "MasterCard", "RuPay", "Amex"],
          "description": "Card network"
        },
        "card_last4": {
          "type": "string",
          "pattern": "^[0-9]{4}$",
          "description": "Last 4 digits of the card number, for display only"
        },
        "card_type": {
          "type": "string",
          "enum": ["credit", "debit"],
          "description": "Card funding type"
        },
        "cvv": {
          "type": "string",
          "description": "CVV encrypted by the PSP SDK; never transmitted as plaintext and never stored"
        },
        "emi_plan_id": {
          "type": "string",
          "description": "EMI plan ID from the PSP, if the buyer selected EMI"
        },
        "save_card": {
          "type": "boolean",
          "description": "Whether the buyer opted to save this card for future use",
          "default": false
        },
        "recurring": {
          "type": "boolean",
          "description": "Whether this is a recurring mandate payment",
          "default": false
        }
      },
      "required": ["type", "token_id", "card_network", "card_last4", "card_type"],
      "example": {
        "type": "s2s_card",
        "token_id": "tok_abc123xyz",
        "card_network": "Visa",
        "card_last4": "4242",
        "card_type": "credit",
        "save_card": true,
        "recurring": false
      }
    },
    "RiskSignal": {
      "description": "Device and session signals used for fraud detection on S2S card transactions",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of risk signal detected"
        },
        "score": {
          "type": "integer",
          "description": "Risk score indicating severity level"
        },
        "action": {
          "type": "string",
          "enum": ["blocked", "manual_review", "authorized"],
          "description": "Recommended action based on risk assessment"
        }
      },
      "required": ["type", "score", "action"],
      "example": {
        "type": "card_testing",
        "score": 5,
        "action": "authorized"
      }
    },
    "Allowance": {
      "description": "Constraints on how the S2S card payment can be used for a single transaction (amount limit, expiration, merchant). Identical shape to the base ACP Allowance.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "enum": ["one_time"],
          "description": "Usage pattern for this allowance; currently only one_time is supported"
        },
        "max_amount": {
          "type": "integer",
          "description": "Maximum charge amount in minor units (e.g., paise for INR)"
        },
        "currency": {
          "type": "string",
          "pattern": "^[a-z]{3}$",
          "description": "ISO-4217 three-letter lowercase currency code (e.g., 'inr')"
        },
        "checkout_session_id": {
          "type": "string",
          "description": "Identifier of the ACP checkout session this payment is for"
        },
        "merchant_id": {
          "type": "string",
          "maxLength": 256,
          "description": "Unique identifier for the merchant authorized to collect this payment"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this allowance expires"
        }
      },
      "required": ["reason", "max_amount", "currency", "checkout_session_id", "merchant_id", "expires_at"],
      "example": {
        "reason": "one_time",
        "max_amount": 49900,
        "currency": "inr",
        "checkout_session_id": "csn_01HV3P3XYZ789",
        "merchant_id": "psp_live_abc123xyz",
        "expires_at": "2026-04-15T10:45:00Z"
      }
    },
    "DelegatePaymentRequest": {
      "description": "Request to initiate an S2S card payment. The platform tokenizes the card via the PSP SDK, then submits this request to charge the token.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "payment_method": {
          "$ref": "#/$defs/PaymentMethodS2SCard",
          "description": "The tokenized card payment method"
        },
        "allowance": {
          "$ref": "#/$defs/Allowance",
          "description": "Constraints on how this payment can be used for this transaction"
        },
        "billing_address": {
          "type": "object",
          "additionalProperties": false,
          "description": "Billing address associated with the card. Required for some networks and issuers.",
          "properties": {
            "name": { "type": "string", "maxLength": 256, "description": "Full name of the cardholder" },
            "line_one": { "type": "string", "maxLength": 60, "description": "Street address line 1" },
            "line_two": { "type": "string", "maxLength": 60, "description": "Street address line 2" },
            "city": { "type": "string", "maxLength": 60, "description": "City or locality" },
            "state": { "type": "string", "description": "State, province, or region" },
            "country": { "type": "string", "minLength": 2, "maxLength": 2, "description": "ISO-3166-1 alpha-2 country code" },
            "postal_code": { "type": "string", "maxLength": 20, "description": "ZIP or postal code" }
          },
          "required": ["name", "line_one", "city", "state", "country", "postal_code"]
        },
        "risk_signals": {
          "type": "array",
          "description": "Risk assessment signals from the platform's fraud detection system",
          "items": {
            "$ref": "#/$defs/RiskSignal"
          }
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata for the request",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["payment_method", "allowance", "risk_signals", "metadata"],
      "example": {
        "payment_method": {
          "type": "s2s_card",
          "token_id": "tok_abc123xyz",
          "card_network": "Visa",
          "card_last4": "4242",
          "card_type": "credit",
          "save_card": true
        },
        "allowance": {
          "reason": "one_time",
          "max_amount": 49900,
          "currency": "inr",
          "checkout_session_id": "csn_01HV3P3XYZ789",
          "merchant_id": "psp_live_abc123xyz",
          "expires_at": "2026-04-15T10:45:00Z"
        },
        "billing_address": {
          "name": "Priya Sharma",
          "line_one": "12 MG Road",
          "city": "Bengaluru",
          "state": "Karnataka",
          "country": "IN",
          "postal_code": "560001"
        },
        "risk_signals": [
          {
            "type": "card_testing",
            "score": 5,
            "action": "authorized"
          }
        ],
        "metadata": {
          "session_id": "sess_abc123",
          "user_agent": "ChatGPT/4.0"
        }
      }
    },
    "DelegatePaymentResponse": {
      "description": "Response confirming the S2S card payment was accepted. PSP-specific confirmation values (e.g., payment_id, order_id) are returned in metadata for merchant reconciliation.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this delegated payment record"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this delegated payment record was created"
        },
        "metadata": {
          "type": "object",
          "description": "Metadata echoed from the request plus system-added fields. MAY include PSP-specific confirmation values such as payment_id and order_id for merchant reconciliation.",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": ["id", "created", "metadata"],
      "example": {
        "id": "dp_card_NmtIbizJ5JUEmH",
        "created": "2026-04-15T10:32:00Z",
        "metadata": {
          "payment_id": "pay_NmtIbizJ5JUEmH",
          "order_id": "order_NmtIbizJ5JUEmX",
          "session_id": "sess_abc123",
          "merchant_id": "psp_live_abc123xyz"
        }
      }
    },
    "ThreeDSNextAction": {
      "description": "3DS challenge details returned when the issuing bank requires authentication before capture. The platform renders the ACS URL in an inline iframe.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "const": "redirect_to_url",
          "description": "Always 'redirect_to_url' for 3DS inline iframe rendering"
        },
        "redirect_to_url": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "url": {
              "type": "string",
              "format": "uri",
              "description": "ACS URL for the 3DS challenge iframe"
            },
            "return_url": {
              "type": "string",
              "format": "uri",
              "description": "Merchant callback URL after 3DS completion"
            }
          },
          "required": ["url", "return_url"]
        }
      },
      "required": ["type", "redirect_to_url"],
      "example": {
        "type": "redirect_to_url",
        "redirect_to_url": {
          "url": "https://acs.bank.com/3ds/challenge?txid=abc123",
          "return_url": "https://merchant.example.com/acp/3ds/callback"
        }
      }
    },
    "Error": {
      "description": "Error response for S2S card payment operations",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "invalid_request",
            "rate_limit_exceeded",
            "processing_error",
            "service_unavailable"
          ],
          "description": "High-level error category"
        },
        "code": {
          "type": "string",
          "enum": [
            "invalid_token",
            "cvv_required",
            "card_declined",
            "card_expired",
            "insufficient_funds",
            "authentication_failed",
            "daily_limit_exceeded",
            "international_blocked",
            "duplicate_request",
            "idempotency_conflict",
            "too_many_requests",
            "idempotency_key_required",
            "idempotency_in_flight"
          ],
          "description": "Specific error code for programmatic handling"
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message"
        },
        "param": {
          "type": "string",
          "description": "JSONPath of the offending field, if applicable"
        },
        "supported_versions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "API version in YYYY-MM-DD format"
          },
          "description": "API versions supported by the server, newest first. Only present on version-related errors."
        }
      },
      "required": ["type", "code", "message"],
      "example": {
        "type": "processing_error",
        "code": "card_declined",
        "message": "Bank declined the transaction. Please retry or use another card.",
        "param": "$.payment_method.token_id"
      }
    }
  }
}
