  },
  "flow_diagram": {
    "mandate_setup_flow": [
      "1. Widget calls window.openai.openExternal with Razorpay UPI Circle onboarding URL",
      "2. User authenticates with UPI PIN and approves mandate",
      "3. Razorpay redirects to merchant with mandate_id",
      "4. Merchant stores mandate_id against acp_user_id",
      "5. Subsequent purchases use mandate without user interaction"
    ],
    "purchase_flow": [
      "1. Widget calls window.openai.requestCheckout with payment_type: upi_circle",
      "2. Platform validates mandate (amount within ceiling, not expired)",
      "3. Platform shows pre-confirmation message to user",
      "4. User confirms, platform calls Razorpay UPI Circle debit API",
      "5. Razorpay executes agent-initiated debit via NPCI",
      "6. Platform calls complete_checkout with payment details",
      "7. Merchant verifies signature server-side",
      "8. Order fulfilled, user notified"
    ]
  }
