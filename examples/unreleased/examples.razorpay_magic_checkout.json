{
  "handler_declaration_app_manifest": {
    "payment": {
      "handlers": [
        {
          "id": "razorpay_magic_001",
          "name": "com.razorpay.magic_checkout",
          "version": "2026-04-07",
          "spec": "https://razorpay.com/acp/magic_checkout/2026-04-07/spec.md",
          "schema": "https://example.com/schemas/redirect-checkout/bundle.schema.json",
          "config": {
            "environment": "production",
            "merchant_id": "rzp_live_abc123xyz",
            "merchant_name": "Razorpay Demo Store",
            "supported_methods": ["upi", "card", "netbanking", "wallet", "emi", "bnpl", "cod"]
          }
        }
      ]
    },
    "checkout_config": {
      "checkout_type": "redirect",
      "payment_provider": {
        "name": "razorpay",
        "payment_type": "magic_checkout",
        "handler_id": "razorpay_magic_001"
      }
    }
  },

  "request_checkout_from_widget": {
    "checkout_type": "redirect",
    "currency": "INR",
    "amount": 57700,
    "line_items": [
      {
        "id": "sku_milk",
        "name": "Amul Full Cream Milk 1L",
        "quantity": 2,
        "unit_price": 28850
      }
    ],
    "payment_provider": {
      "name": "razorpay",
      "payment_type": "magic_checkout",
      "handler_id": "razorpay_magic_001"
    }
  },

  "mcp_initiate_checkout_escalation_response": {
    "status": "requires_escalation",
    "payment": {
      "instruments": [
        {
          "id": "inst_hosted_001",
          "handler_id": "razorpay_magic_001",
          "type": "hosted_checkout",
          "credential": {
            "type": "hosted_checkout",
            "checkout_url": "https://checkout.razorpay.com/v1/checkout/order_xyz789?prefill%5Bemail%5D=buyer%40example.com&prefill%5Bcontact%5D=%2B919876543210&prefill%5Bname%5D=Priya%20Sharma&retry=true&callback_url=https%3A%2F%2Fapi.merchant.com%2Facp%2Fchk_abc123%2Freturn&cancel_url=https%3A%2F%2Fapi.merchant.com%2Facp%2Fchk_abc123%2Fcancel",
            "session_id": "order_xyz789",
            "return_url": "https://api.merchant.com/acp/chk_abc123/return",
            "cancel_url": "https://api.merchant.com/acp/chk_abc123/cancel"
          }
        }
      ]
    }
  },

  "complete_checkout_mcp_request": {
    "tool": "complete_checkout",
    "payment_data": {
      "type": "hosted_checkout",
      "provider": "razorpay",
      "session_id": "order_xyz789",
      "status": "captured",
      "amount": 57700,
      "currency": "INR"
    }
  },

  "get_checkout_completed_response": {
    "id": "chk_abc123",
    "status": "completed",
    "order": {
      "id": "ord_chk_abc123",
      "permalink_url": "https://dashboard.razorpay.com/orders/ord_chk_abc123"
    }
  },

  "error_invalid_merchant_id": {
    "type": "invalid_request",
    "code": "invalid_merchant_id",
    "message": "Merchant ID not found or inactive. Verify account and key mode (test vs. live).",
    "param": "$.config.merchant_id"
  },

  "error_magic_checkout_disabled": {
    "type": "invalid_request",
    "code": "checkout_disabled",
    "message": "Magic Checkout not enabled on account. Activate in Dashboard → Settings → Magic Checkout."
  },

  "error_unsupported_currency": {
    "type": "invalid_request",
    "code": "unsupported_currency",
    "message": "Currency not supported. This handler supports INR only.",
    "param": "$.currency"
  },

  "error_order_creation_failed": {
    "type": "processing_error",
    "code": "order_creation_failed",
    "message": "Razorpay order creation failed. Verify amount ≥ 100 paise; retry with exponential backoff."
  },

  "error_checkout_expired": {
    "type": "invalid_request",
    "code": "checkout_expired",
    "message": "ACP checkout session or Razorpay order expired. Create a new checkout session."
  }
}
